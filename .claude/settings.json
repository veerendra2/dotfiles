{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(gh api:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(gh search:*)",
      "Bash(grep -v \"^$\")",
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Read(~/.zshrc)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebSearch"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "OTEL_METRICS_EXPORTER": "otlp"
  },
  "mcpServers": {
    "atlassian": {
      "transport": {
        "type": "docker",
        "image": "mcp/atlassian"
      }
    }
  }
}
